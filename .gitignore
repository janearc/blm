# python build artifacts. Big Little Mesh had no .gitignore, so compiled bytecode got committed
# (gen/python + python/frood) -- the P6 hygiene the frood design flagged.
__pycache__/
*.pyc
*.pyo

# go
/bin/

# local env
.env
.venv/

# built protoc plugins (use `go install ./cmd/...`)
/protoc-gen-fsm
/protoc-gen-swift-codable
/protoc-gen-rust-serde

# rust (the generated gen/rust crate is committed; its build output is not). Cargo.lock is
# omitted because gen/rust is a library consumed via a git/path dependency -- the consumer's
# lock governs the build.
gen/rust/target/
gen/rust/Cargo.lock

# swift package build artifacts (Package.swift is at the repo root)
.build/
.swiftpm/

# python build artifacts
dist/
build/
*.egg-info/
